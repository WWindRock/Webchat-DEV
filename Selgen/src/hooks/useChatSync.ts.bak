'use client'

import { useState, useEffect, useCallback, useRef } from 'react'

export interface ChatSession {
  id: string
  session_id: string
  name: string
  updated_at: string
  created_at: string
  userId?: string
}

interface SessionData {
  messages: any[]
  canvas: {
    nodes: any[]
    edges: any[]
  }
  name: string
  updated_at: string
  userId?: string
}

export function useChatSync(currentUser: { username: string } | null) {
  const [sessions, setSessions] = useState<ChatSession[]>([])
  const [isLoading, setIsLoading] = useState(false)
  const [error, setError] = useState<string | null>(null)
  const lastUpdatedRef = useRef<string | null>(null)
  const pollingIntervalRef = useRef<NodeJS.Timeout | null>(null)
  
  const userId = currentUser?.username || 'anonymous'
  const SESSIONS_LIST_KEY = `selgen_sessions_list_${userId}`
  const SESSION_DATA_PREFIX = `selgen_session_data_${userId}_`

  const loadSessionsFromStorage = useCallback(() => {
    try {
      const stored = localStorage.getItem(SESSIONS_LIST_KEY)
      if (stored) {
        const parsed = JSON.parse(stored)
        if (Array.isArray(parsed)) {
          const sorted = parsed.sort((a: ChatSession, b: ChatSession) => 
            new Date(b.updated_at).getTime() - new Date(a.updated_at).getTime()
          )
          setSessions(sorted)
          return sorted
        }
      }
    } catch (err) {
      console.error('Failed to load sessions from storage:', err)
    }
    setSessions([])
    return []
  }, [SESSIONS_LIST_KEY])

  const saveSessionsToStorage = useCallback((sessionList: ChatSession[]) => {
    try {
      localStorage.setItem(SESSIONS_LIST_KEY, JSON.stringify(sessionList))
    } catch (err) {
      console.error('Failed to save sessions to storage:', err)
    }
  }, [SESSIONS_LIST_KEY])

  const syncWith7088 = useCallback(async () => {
    if (userId !== 'admin') return
    
    try {
      const response = await fetch('http://107.172.137.173:7088/api/sessions', {
        method: 'GET',
        headers: {
          'Content-Type': 'application/json',
        },
      })
      
      if (response.ok) {
        const data = await response.json()
        if (Array.isArray(data)) {
          const currentSessions = await loadSessionsFromStorage()
          const sessionMap = new Map<string, ChatSession>()
          
          currentSessions.forEach((s: ChatSession) => {
            sessionMap.set(s.session_id, s)
          })
          
          data.forEach((s: ChatSession) => {
            if (!sessionMap.has(s.session_id)) {
              sessionMap.set(s.session_id, { ...s, userId: s.userId || 'unknown' })
            } else {
              const existing = sessionMap.get(s.session_id)!
              if (new Date(s.updated_at) > new Date(existing.updated_at)) {
                sessionMap.set(s.session_id, { ...s, userId: s.userId || 'unknown' })
              }
            }
          })
          
          const merged = Array.from(sessionMap.values()).sort((a: ChatSession, b: ChatSession) => 
            new Date(b.updated_at).getTime() - new Date(a.updated_at).getTime()
          )
          
          setSessions(merged)
          saveSessionsToStorage(merged)
        }
      }
    } catch (err) {
      console.error('Failed to sync with 7088:', err)
    }
  }, [userId, loadSessionsFromStorage, saveSessionsToStorage])

  const fetchSessions = useCallback(async () => {
    if (!currentUser) {
      setSessions([])
      return
    }
    
    setIsLoading(true)
    setError(null)
    try {
      const res = await fetch('/api/history')
      if (res.ok) {
        const data = await res.json()
        const apiSessions = Array.isArray(data) ? data : []
        
        const storedSessions = loadSessionsFromStorage()
        
        const sessionMap = new Map<string, ChatSession>()
        
        storedSessions.forEach((s: ChatSession) => {
          sessionMap.set(s.session_id, { ...s, userId })
        })
        
        apiSessions.forEach((s: ChatSession) => {
          if (!sessionMap.has(s.session_id)) {
            sessionMap.set(s.session_id, { ...s, userId })
          } else {
            const existing = sessionMap.get(s.session_id)!
            if (new Date(s.updated_at) > new Date(existing.updated_at)) {
              sessionMap.set(s.session_id, { ...s, userId })
            }
          }
        })
        
        const merged = Array.from(sessionMap.values()).sort((a: ChatSession, b: ChatSession) => 
          new Date(b.updated_at).getTime() - new Date(a.updated_at).getTime()
        )
        
        const latestUpdated = merged[0]?.updated_at || null
        if (latestUpdated !== lastUpdatedRef.current) {
          setSessions(merged)
          saveSessionsToStorage(merged)
          lastUpdatedRef.current = latestUpdated
        }
      }
      
      if (userId === 'admin') {
        await syncWith7088()
      }
    } catch (err) {
      console.error('Failed to fetch chat sessions:', err)
      loadSessionsFromStorage()
      setError(err instanceof Error ? err.message : 'Failed to sync chats')
    } finally {
      setIsLoading(false)
    }
  }, [currentUser, userId, loadSessionsFromStorage, saveSessionsToStorage, syncWith7088])

  const createSession = useCallback((name?: string): ChatSession => {
    const now = new Date().toISOString()
    const sessionId = `session_${Date.now()}_${Math.random().toString(36).substr(2, 9)}`
    const newSession: ChatSession = {
      id: sessionId,
      session_id: sessionId,
      name: name || `新会话 ${sessions.length + 1}`,
      created_at: now,
      updated_at: now,
      userId,
    }
    
    const updatedSessions = [newSession, ...sessions]
    setSessions(updatedSessions)
    saveSessionsToStorage(updatedSessions)
    
    return newSession
  }, [sessions, userId, saveSessionsToStorage])

  const updateSession = useCallback((sessionId: string, updates: Partial<ChatSession>) => {
    const updatedSessions = sessions.map(s => 
      s.session_id === sessionId 
        ? { ...s, ...updates, updated_at: new Date().toISOString(), userId }
        : s
    )
    setSessions(updatedSessions)
    saveSessionsToStorage(updatedSessions)
  }, [sessions, userId, saveSessionsToStorage])

  const renameSession = useCallback((sessionId: string, newName: string) => {
    updateSession(sessionId, { name: newName })
  }, [updateSession])

  const deleteSession = useCallback((sessionId: string) => {
    const updatedSessions = sessions.filter(s => s.session_id !== sessionId)
    setSessions(updatedSessions)
    saveSessionsToStorage(updatedSessions)
    
    try {
      localStorage.removeItem(`${SESSION_DATA_PREFIX}${sessionId}`)
    } catch (err) {
      console.error('Failed to delete session data:', err)
    }
  }, [sessions, SESSION_DATA_PREFIX, saveSessionsToStorage])

  const getSessionData = useCallback((sessionId: string): SessionData | null => {
    try {
      const stored = localStorage.getItem(`${SESSION_DATA_PREFIX}${sessionId}`)
      if (stored) {
        const data = JSON.parse(stored)
        if (data.userId === userId || userId === 'admin') {
          return data
        }
      }
    } catch (err) {
      console.error('Failed to load session data:', err)
    }
    return null
  }, [SESSION_DATA_PREFIX, userId])

  const saveSessionData = useCallback((sessionId: string, data: Partial<SessionData>) => {
    try {
      const existing = getSessionData(sessionId) || {
        messages: [],
        canvas: { nodes: [], edges: [] },
        name: '',
        updated_at: new Date().toISOString(),
        userId,
      }
      const updated = { ...existing, ...data, updated_at: new Date().toISOString(), userId }
      localStorage.setItem(`${SESSION_DATA_PREFIX}${sessionId}`, JSON.stringify(updated))
      
      updateSession(sessionId, { updated_at: updated.updated_at })
    } catch (err) {
      console.error('Failed to save session data:', err)
    }
  }, [SESSION_DATA_PREFIX, userId, getSessionData, updateSession])

  const getAllUsersSessions = useCallback((): { userId: string; sessions: ChatSession[] }[] => {
    if (userId !== 'admin') return []
    
    const result: { userId: string; sessions: ChatSession[] }[] = []
    const userSet = new Set<string>()
    
    for (let i = 0; i < localStorage.length; i++) {
      const key = localStorage.key(i)
      if (key?.startsWith('selgen_sessions_list_')) {
        const uid = key.replace('selgen_sessions_list_', '')
        userSet.add(uid)
      }
    }
    
    userSet.forEach(uid => {
      try {
        const stored = localStorage.getItem(`selgen_sessions_list_${uid}`)
        if (stored) {
          const parsed = JSON.parse(stored)
          if (Array.isArray(parsed)) {
            result.push({ userId: uid, sessions: parsed })
          }
        }
      } catch (err) {
        console.error(`Failed to load sessions for user ${uid}:`, err)
      }
    })
    
    return result
  }, [userId])

  useEffect(() => {
    if (currentUser) {
      loadSessionsFromStorage()
      fetchSessions()
    } else {
      setSessions([])
    }
  }, [currentUser, fetchSessions, loadSessionsFromStorage])

  useEffect(() => {
    if (!currentUser) return
    
    const startPolling = () => {
      pollingIntervalRef.current = setInterval(() => {
        fetchSessions()
      }, 3000)
    }

    startPolling()

    return () => {
      if (pollingIntervalRef.current) {
        clearInterval(pollingIntervalRef.current)
      }
    }
  }, [currentUser, fetchSessions])

  const refresh = useCallback(() => {
    return fetchSessions()
  }, [fetchSessions])

  return {
    sessions,
    isLoading,
    error,
    refresh,
    createSession,
    renameSession,
    deleteSession,
    getSessionData,
    saveSessionData,
    getAllUsersSessions,
  }
}
